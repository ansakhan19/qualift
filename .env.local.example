# Copy this file to .env.local and fill in your values

# Resend API key — get one free at resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# The email address magic links are sent FROM (must be a verified domain in Resend)
EMAIL_FROM=noreply@yourdomain.com

# Your app's public URL (used to build magic link URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SQLite database file path
# Local:   ./qualift.db
# Railway: /data/qualift.db  (set this when deploying — /data is your mounted volume)
DB_PATH=./qualift.db

# Secret for signing tokens (generate with: openssl rand -hex 32)
TOKEN_SECRET=change_me_to_a_random_secret
